{
    "name": "bb-extension",
    "displayName": "Bots Business Extension",
    "description": "Professional VS Code extension for Bots Business: manage commands, folders, and libraries with a premium integrated development environment featuring real-time status and error diagnostics. made with love by @arijitiyan",
    "version": "0.0.1",
    "publisher": "bottercc",
    "repository": {
        "type": "git",
        "url": "https://github.com/nasirul786/bb-vsc-extension.git"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "bbe.login",
                "title": "BBE: login"
            },
            {
                "command": "bbe.loadBots",
                "title": "BBE: My Bots"
            },
            {
                "command": "bbe.loadLibraries",
                "title": "BBE: load libraries"
            },
            {
                "command": "bbe.openCommand",
                "title": "Open Command"
            },
            {
                "command": "bbe.createFolder",
                "title": "Create Folder",
                "icon": "$(new-folder)"
            },
            {
                "command": "bbe.createCommand",
                "title": "Create Command",
                "icon": "$(new-file)"
            },
            {
                "command": "bbe.deleteCommand",
                "title": "Delete Command",
                "icon": "$(trash)"
            },
            {
                "command": "bbe.copyFolderId",
                "title": "Copy Folder ID"
            },
            {
                "command": "bbe.deleteFolder",
                "title": "Delete Folder",
                "icon": "$(trash)"
            },
            {
                "command": "bbe.startStopBot",
                "title": "Start/Stop Bot"
            },
            {
                "command": "bbe.copyBotId",
                "title": "Copy Bot ID"
            },
            {
                "command": "bbe.installLib",
                "title": "Install Lib"
            },
            {
                "command": "bbe.viewInstalledLibs",
                "title": "View Installed Libs"
            },
            {
                "command": "bbe.uninstallLib",
                "title": "Uninstall a Lib"
            },
            {
                "command": "bbe.viewErrorLogs",
                "title": "Error logs"
            },
            {
                "command": "bbe.botMore",
                "title": "More",
                "icon": "$(more)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "bbe-extension",
                    "title": "Bots Business",
                    "icon": "$(robot)"
                }
            ]
        },
        "views": {
            "bbe-extension": [
                {
                    "id": "bbe-bots",
                    "name": "My Bots"
                }
            ]
        },
        "menus": {
            "commandPalette": [
                {
                    "command": "bbe.createFolder",
                    "when": "false"
                },
                {
                    "command": "bbe.createCommand",
                    "when": "false"
                },
                {
                    "command": "bbe.deleteCommand",
                    "when": "false"
                },
                {
                    "command": "bbe.openCommand",
                    "when": "false"
                },
                {
                    "command": "bbe.copyFolderId",
                    "when": "false"
                },
                {
                    "command": "bbe.deleteFolder",
                    "when": "false"
                },
                {
                    "command": "bbe.startStopBot",
                    "when": "false"
                },
                {
                    "command": "bbe.copyBotId",
                    "when": "false"
                },
                {
                    "command": "bbe.installLib",
                    "when": "false"
                },
                {
                    "command": "bbe.viewInstalledLibs",
                    "when": "false"
                },
                {
                    "command": "bbe.uninstallLib",
                    "when": "false"
                },
                {
                    "command": "bbe.viewErrorLogs",
                    "when": "false"
                },
                {
                    "command": "bbe.botMore",
                    "when": "false"
                }
            ],
            "view/item/context": [
                {
                    "command": "bbe.createFolder",
                    "when": "view == bbe-bots && viewItem == bot-isolated",
                    "group": "inline"
                },
                {
                    "command": "bbe.createCommand",
                    "when": "view == bbe-bots && (viewItem == bot-isolated || viewItem == folder)",
                    "group": "inline"
                },
                {
                    "command": "bbe.deleteCommand",
                    "when": "view == bbe-bots && viewItem == command",
                    "group": "inline"
                },
                {
                    "command": "bbe.copyFolderId",
                    "when": "view == bbe-bots && viewItem == folder"
                },
                {
                    "command": "bbe.deleteFolder",
                    "when": "view == bbe-bots && viewItem == folder"
                },
                {
                    "command": "bbe.botMore",
                    "when": "view == bbe-bots && viewItem == bot-isolated",
                    "group": "inline"
                },
                {
                    "command": "bbe.startStopBot",
                    "when": "view == bbe-bots && (viewItem == bot || viewItem == bot-isolated)",
                    "group": "bot-actions"
                },
                {
                    "command": "bbe.copyBotId",
                    "when": "view == bbe-bots && (viewItem == bot || viewItem == bot-isolated)",
                    "group": "bot-actions"
                },
                {
                    "command": "bbe.installLib",
                    "when": "view == bbe-bots && (viewItem == bot || viewItem == bot-isolated)",
                    "group": "bot-actions"
                },
                {
                    "command": "bbe.viewInstalledLibs",
                    "when": "view == bbe-bots && (viewItem == bot || viewItem == bot-isolated)",
                    "group": "bot-actions"
                },
                {
                    "command": "bbe.uninstallLib",
                    "when": "view == bbe-bots && (viewItem == bot || viewItem == bot-isolated)",
                    "group": "bot-actions"
                },
                {
                    "command": "bbe.viewErrorLogs",
                    "when": "view == bbe-bots && (viewItem == bot || viewItem == bot-isolated)",
                    "group": "bot-actions"
                }
            ]
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "16.x",
        "typescript": "^5.1.3",
        "eslint": "^8.41.0",
        "@typescript-eslint/parser": "^5.59.8",
        "@typescript-eslint/eslint-plugin": "^5.59.8"
    }
}